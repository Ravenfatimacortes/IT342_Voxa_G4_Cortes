# ----------------------------------------------------------------------------
# Maven Start Up Batch script (UN*X)
# ----------------------------------------------------------------------------

# Resolve links: $0 may be a link to a directory
PRG="$0"
while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if [ "$link" != "" ] ; then
        PRG="$link"
    fi
done

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
else
    JAVACMD="java"
fi

# Execute Maven
exec "$JAVACMD" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$MAVEN_HOME/boot/plexus-classworlds-*.jar" \
  "-Dclassworlds.app=org.codehaus.plexus.classworlds.launcher.Launcher" \
  "-Dmaven.home=${MAVEN_HOME}" \
  "-Dmaven.multiModuleProject=${MAVEN_MULTIMODULE_PROJECT}" \
  org.codehaus.plexus.classworlds.launcher.Launcher \
  $MAVEN_CMD_LINE_ARGS \
  $MAVEN_PROJECT_STARTER
